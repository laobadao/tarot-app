/* 首页样式 */
.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 头部 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 60rpx;
  position: relative;
}

.stars {
  position: absolute;
  top: 30rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  padding: 0 40rpx;
}

.star {
  font-size: 24rpx;
  color: var(--accent-gold);
  opacity: 0.6;
}

.star-1 { animation: twinkle 2s ease-in-out infinite; }
.star-2 { animation: twinkle 2.5s ease-in-out infinite 0.3s; }
.star-3 { animation: twinkle 3s ease-in-out infinite 0.6s; }
.star-4 { animation: twinkle 2.2s ease-in-out infinite 0.9s; }
.star-5 { animation: twinkle 2.8s ease-in-out infinite 1.2s; }

.title {
  font-size: 72rpx;
  color: var(--accent-gold);
  font-weight: bold;
  letter-spacing: 16rpx;
  text-shadow: 0 0 40rpx rgba(212, 175, 55, 0.6);
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 8rpx;
  margin-bottom: 30rpx;
}

.motto {
  font-size: 26rpx;
  color: var(--text-primary);
  opacity: 0.8;
  font-style: italic;
}

/* 最近占卜 */
.recent-reading {
  margin: 20rpx 30rpx;
  padding: 30rpx;
}

.recent-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.recent-title {
  font-size: 28rpx;
  color: var(--accent-gold);
  font-weight: bold;
}

.recent-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.recent-spread {
  display: block;
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.recent-question {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 牌阵选择区 */
.spread-section {
  padding: 20rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  color: var(--accent-gold);
  font-weight: bold;
  margin-bottom: 30rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.spread-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.spread-card {
  width: calc(50% - 20rpx);
  min-width: 300rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.spread-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.3);
}

.spread-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 16rpx;
}

.spread-name {
  display: block;
  font-size: 30rpx;
  color: var(--accent-gold);
  font-weight: bold;
  margin-bottom: 12rpx;
}

.spread-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.spread-meta {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 20rpx;
  color: var(--text-primary);
  background: rgba(212, 175, 55, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 底部 */
.footer {
  padding: 60rpx 40rpx;
  text-align: center;
}

.moon-phases {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  opacity: 0.6;
}

.copyright {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
}
