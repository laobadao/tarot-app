<view class="container mystic-bg">
  <!-- 头部装饰 -->
  <view class="header">
    <view class="stars">
      <text class="star star-1">✦</text>
      <text class="star star-2">✧</text>
      <text class="star star-3">✦</text>
      <text class="star star-4">✧</text>
      <text class="star star-5">✦</text>
    </view>
    <text class="title">神秘塔罗</text>
    <text class="subtitle">Mystic Tarot</text>
    <text class="motto">{{motto}}</text>
  </view>

  <!-- 最近占卜 -->
  <view wx:if="{{lastReading}}" class="recent-reading card-container" bindtap="viewHistory">
    <view class="recent-header">
      <text class="recent-title">最近占卜</text>
      <text class="recent-time">{{lastReading.time}}</text>
    </view>
    <text class="recent-spread">{{lastReading.spreadName}}</text>
    <text class="recent-question">{{lastReading.question || '无问题'}}</text>
  </view>

  <!-- 牌阵选择 -->
  <view class="spread-section">
    <text class="section-title">选择牌阵</text>
    
    <view class="spread-grid">
      <view 
        class="spread-card card-container" 
        wx:for="{{spreads}}" 
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectSpread"
      >
        <text class="spread-icon">{{item.icon}}</text>
        <text class="spread-name">{{item.name}}</text>
        <text class="spread-desc">{{item.description}}</text>
        <view class="spread-meta">
          <text class="meta-item">{{item.cardCount}} 张牌</text>
          <text class="meta-item">{{item.difficulty}}</text>
          <text class="meta-item">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="footer">
    <view class="moon-phases">
      <text>🌑</text>
      <text>🌒</text>
      <text>🌓</text>
      <text>🌔</text>
      <text>🌕</text>
      <text>🌖</text>
      <text>🌗</text>
      <text>🌘</text>
    </view>
    <text class="copyright">✨ 愿星辰指引你 ✨</text>
  </view>
</view>
