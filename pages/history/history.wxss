/* 历史页样式 */
.container {
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx;
}

.page-title {
  display: block;
  font-size: 44rpx;
  color: var(--accent-gold);
  font-weight: bold;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 34rpx;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

/* 历史列表 */
.history-list {
  padding: 20rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
}

.list-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.clear-btn {
  font-size: 26rpx;
  color: #ff6b6b;
}

.history-item {
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-spread {
  font-size: 32rpx;
  color: var(--accent-gold);
  font-weight: bold;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.item-question {
  font-size: 26rpx;
  color: var(--text-primary);
  font-style: italic;
  margin-bottom: 16rpx;
}

.item-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.card-tag {
  font-size: 22rpx;
  color: var(--text-primary);
  background: rgba(212, 175, 55, 0.15);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.item-actions {
  display: flex;
  gap: 30rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.action-btn {
  font-size: 26rpx;
  color: var(--accent-gold);
}

.action-btn.delete {
  color: #ff6b6b;
}
