/* 全局样式 - 复古神秘风格 */
page {
  --primary-dark: #1a0a2e;
  --primary-purple: #2d1b4e;
  --accent-gold: #d4af37;
  --accent-gold-light: #f4d03f;
  --text-primary: #e8d5b7;
  --text-secondary: #b8a9c9;
  --border-color: #4a3b5c;
  --card-bg: #241636;
  
  background-color: var(--primary-dark);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  min-height: 100vh;
}

/* 神秘背景纹理 */
.mystic-bg {
  background: 
    radial-gradient(ellipse at top, rgba(212, 175, 55, 0.1) 0%, transparent 50%),
    radial-gradient(ellipse at bottom, rgba(45, 27, 78, 0.3) 0%, transparent 50%),
    linear-gradient(180deg, #1a0a2e 0%, #0d0518 100%);
  min-height: 100vh;
  position: relative;
}

.mystic-bg::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 30%, rgba(212, 175, 55, 0.03) 0%, transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(212, 175, 55, 0.03) 0%, transparent 40%);
  pointer-events: none;
  z-index: 0;
}

/* 金色标题 */
.gold-title {
  color: var(--accent-gold);
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.5);
  letter-spacing: 4rpx;
}

/* 神秘按钮 */
.mystic-btn {
  background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
  color: #1a0a2e;
  border: none;
  border-radius: 50rpx;
  padding: 30rpx 60rpx;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  box-shadow: 0 4rpx 20rpx rgba(212, 175, 55, 0.3);
  transition: all 0.3s ease;
}

.mystic-btn::after {
  border: none;
}

.mystic-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.2);
}

/* 卡片容器 */
.card-container {
  background: linear-gradient(135deg, var(--card-bg) 0%, var(--primary-purple) 100%);
  border: 2rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.3);
}

/* 分隔线装饰 */
.divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--accent-gold), transparent);
  margin: 30rpx 0;
}

/* 加载动画 */
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-spin {
  animation: rotate 2s linear infinite;
}

/* 星星闪烁动画 */
@keyframes twinkle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.star {
  animation: twinkle 2s ease-in-out infinite;
}

/* 容器安全区 */
.safe-area {
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}
