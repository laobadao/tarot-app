/* 塔罗牌组件样式 - 复古手绘风 */

.tarot-card-container {
  position: relative;
  perspective: 1000rpx;
  display: inline-block;
}

/* 尺寸变体 */
.tarot-card-container.small {
  width: 120rpx;
  height: 200rpx;
}

.tarot-card-container.medium {
  width: 180rpx;
  height: 300rpx;
}

.tarot-card-container.large {
  width: 240rpx;
  height: 400rpx;
}

/* 位置标签 */
.position-label {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #d4af37, #b8941f);
  color: #1a0a2e;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
  white-space: nowrap;
  box-shadow: 0 2rpx 10rpx rgba(212, 175, 55, 0.4);
  z-index: 10;
}

/* 牌面容器 */
.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-inner.flipped {
  transform: rotateY(180deg);
}

/* 正反面通用 */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 16rpx;
  overflow: hidden;
}

/* 牌背 */
.card-back {
  background: linear-gradient(135deg, #1a0a2e 0%, #2d1b4e 50%, #1a0a2e 100%);
  border: 4rpx solid #d4af37;
  box-shadow: 
    inset 0 0 30rpx rgba(212, 175, 55, 0.2),
    0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.back-pattern {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.center-symbol {
  font-size: 60rpx;
  opacity: 0.8;
  text-shadow: 0 0 20rpx rgba(212, 175, 55, 0.5);
}

.corner {
  position: absolute;
  font-size: 24rpx;
  color: #d4af37;
  opacity: 0.6;
}

.corner.top-left { top: 15rpx; left: 15rpx; }
.corner.top-right { top: 15rpx; right: 15rpx; }
.corner.bottom-left { bottom: 15rpx; left: 15rpx; }
.corner.bottom-right { bottom: 15rpx; right: 15rpx; }

.border-pattern {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border: 2rpx dashed rgba(212, 175, 55, 0.4);
  border-radius: 10rpx;
}

/* 牌面 */
.card-front {
  background: linear-gradient(180deg, #f5f0e6 0%, #e8dfd1 100%);
  transform: rotateY(180deg);
  border: 4rpx solid #d4af37;
  box-shadow: 
    inset 0 0 60rpx rgba(139, 119, 101, 0.1),
    0 4rpx 20rpx rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  padding: 16rpx;
  box-sizing: border-box;
}

.card-front.reversed {
  transform: rotateY(180deg) rotate(180deg);
}

/* 牌面头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.card-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #2d1b4e;
}

.card-suit {
  font-size: 22rpx;
  color: #8b7355;
}

/* 牌面艺术区域 */
.card-art {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(45, 27, 78, 0.05));
  border-radius: 12rpx;
  margin: 10rpx 0;
  border: 2rpx solid rgba(212, 175, 55, 0.3);
}

.symbol-container {
  margin-bottom: 15rpx;
}

.major-symbol, .suit-symbol {
  font-size: 80rpx;
  display: block;
  text-align: center;
}

.card-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #2d1b4e;
  text-align: center;
  line-height: 1.3;
}

/* 牌面底部 */
.card-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10rpx;
}

.element {
  font-size: 20rpx;
  color: #8b7355;
  margin-bottom: 8rpx;
}

.keywords {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
}

.keyword {
  font-size: 18rpx;
  color: #5a4a3a;
  background: rgba(212, 175, 55, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

/* 逆位标识 */
.reversed-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: linear-gradient(135deg, #8b0000, #5a0000);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  transform: rotate(-15deg);
  box-shadow: 0 2rpx 8rpx rgba(139, 0, 0, 0.4);
}

/* 翻转动画 */
.flipping .card-inner {
  animation: flipShake 0.6s ease-in-out;
}

@keyframes flipShake {
  0%, 100% { transform: scale(1); }
  25% { transform: scale(1.05) rotate(-2deg); }
  75% { transform: scale(1.05) rotate(2deg); }
}

/* 悬停效果 */
.tarot-card-container.clickable:active {
  transform: scale(0.98);
}

/* 光芒效果 */
.tarot-card-container::before {
  content: '';
  position: absolute;
  top: -20rpx;
  left: -20rpx;
  right: -20rpx;
  bottom: -20rpx;
  background: radial-gradient(ellipse, rgba(212, 175, 55, 0.3) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
  z-index: -1;
}

.tarot-card-container.flipped::before {
  opacity: 1;
}
